<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Foundations — Test Your Foundations</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary:   #4B2E83;
      --primary-dk:#221238;
      --primary-lt:#7A52C4;
      --accent:    #C9A227;
      --accent-lt: #E8CE6E;
      --success:   #2E7D4F;
      --danger:    #B4413C;
      --bg:        #FAF6EE;
      --card:      #ffffff;
      --text:      #241934;
      --muted:     #746C82;
      --border:    #E7E1D3;
      --radius:    10px;
      --shadow:    0 4px 18px rgba(36,20,60,.08);
      --font-display:'Fraunces',Georgia,serif;
      --font-body:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
      --font-mono:'IBM Plex Mono',monospace;
    }
    *{margin:0;padding:0;box-sizing:border-box;}
    html{scroll-behavior:smooth;}
    body{font-family:var(--font-body);
         background:var(--bg);color:var(--text);line-height:1.65;}

    /* ── Nav ── */
    .site-nav{position:sticky;top:0;z-index:100;background:rgba(34,18,56,.94);
              backdrop-filter:blur(6px);padding:.9rem 1.5rem;
              display:flex;align-items:center;justify-content:space-between;
              box-shadow:0 2px 14px rgba(0,0,0,.18);}
    .site-nav .wordmark{font-family:var(--font-display);color:#fff;font-size:1.25rem;
                        font-weight:600;letter-spacing:.3px;text-decoration:none;}
    .site-nav .wordmark span{color:var(--accent-lt);}
    .site-nav .nav-links{display:flex;gap:1.6rem;list-style:none;}
    .site-nav .nav-links a{color:rgba(255,255,255,.78);text-decoration:none;
                           font-size:.85rem;font-weight:500;letter-spacing:.2px;
                           padding-bottom:3px;border-bottom:1px solid transparent;
                           transition:all .2s ease;}
    .site-nav .nav-links a:hover{color:#fff;border-color:var(--accent);}
    @media(max-width:640px){.site-nav .nav-links{display:none;}}

    /* ── Hero ── */
    .hero{position:relative;overflow:hidden;
         background:radial-gradient(ellipse at 85% 15%, rgba(201,162,39,.35), transparent 55%),
                    linear-gradient(160deg,var(--primary) 0%,var(--primary-dk) 78%);
         color:#fff;padding:5rem 1.5rem 4.5rem;text-align:center;}
    .hero .eyebrow{font-family:var(--font-mono);font-size:.75rem;letter-spacing:2.5px;
                   text-transform:uppercase;color:var(--accent-lt);margin-bottom:1.1rem;}
    .hero h1{font-family:var(--font-display);font-size:clamp(2.1rem,5vw,3.4rem);
             font-weight:600;line-height:1.15;max-width:760px;margin:0 auto;}
    .hero h1 em{font-style:italic;color:var(--accent-lt);font-weight:500;}
    .hero p.lede{max-width:560px;margin:1.3rem auto 2rem;color:rgba(255,255,255,.82);
                 font-size:1.05rem;}
    .hero-cta{display:inline-flex;align-items:center;gap:.5rem;background:var(--accent);
             color:var(--primary-dk);font-weight:700;font-size:.95rem;padding:.85rem 1.8rem;
             border-radius:50px;text-decoration:none;transition:all .2s ease;
             box-shadow:0 6px 20px rgba(201,162,39,.35);}
    .hero-cta:hover{background:var(--accent-lt);transform:translateY(-2px);}
    .hero-stats{display:flex;justify-content:center;gap:2.6rem;flex-wrap:wrap;margin-top:3rem;}
    .hero-stats .hstat val{display:block;}
    .hstat{text-align:center;}
    .hstat .hnum{font-family:var(--font-mono);font-size:1.9rem;font-weight:600;color:#fff;}
    .hstat .hlbl{font-size:.72rem;letter-spacing:1.2px;text-transform:uppercase;
                color:rgba(255,255,255,.6);margin-top:.2rem;}

    /* ── Purpose strip ── */
    .purpose{max-width:1000px;margin:0 auto;padding:3.6rem 1.5rem 1rem;text-align:center;}
    .purpose .section-label{font-family:var(--font-mono);font-size:.72rem;letter-spacing:2px;
                            text-transform:uppercase;color:var(--accent);font-weight:600;}
    .purpose h2{font-family:var(--font-display);font-size:1.8rem;color:var(--primary);
               margin:.5rem 0 2rem;font-weight:600;}
    .purpose-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.3rem;}
    .purpose-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);
                 padding:1.8rem 1.4rem;box-shadow:var(--shadow);}
    .purpose-card .p-icon{font-size:1.6rem;margin-bottom:.7rem;}
    .purpose-card h3{font-family:var(--font-display);font-size:1.05rem;color:var(--primary);
                    margin-bottom:.4rem;font-weight:600;}
    .purpose-card p{font-size:.85rem;color:var(--muted);}
    @media(max-width:700px){.purpose-grid{grid-template-columns:1fr;}}

    /* ── Layout ── */
    .app{max-width:900px;margin:1rem auto 0;padding:2.5rem 1rem 0;}
    .app-intro{text-align:center;max-width:640px;margin:0 auto 2rem;}
    .app-intro .section-label{font-family:var(--font-mono);font-size:.72rem;letter-spacing:2px;
                              text-transform:uppercase;color:var(--accent);font-weight:600;}
    .app-intro h2{font-family:var(--font-display);font-size:1.9rem;color:var(--primary);
                 margin:.5rem 0 .6rem;font-weight:600;}
    .app-intro p{color:var(--muted);font-size:.95rem;}

    footer{background:var(--primary-dk);color:rgba(255,255,255,.65);text-align:center;
          padding:2.2rem 1.5rem;margin-top:4rem;font-size:.82rem;}
    footer .foot-word{font-family:var(--font-display);color:#fff;font-size:1.1rem;
                      margin-bottom:.5rem;}
    footer .foot-links{display:flex;justify-content:center;gap:1.3rem;margin:.8rem 0;
                       flex-wrap:wrap;}
    footer .foot-links a{color:rgba(255,255,255,.65);text-decoration:none;font-size:.8rem;}
    footer .foot-links a:hover{color:var(--accent-lt);}

    /* ── Course Selector ── */
    #courseScreen h2{color:var(--primary);margin-bottom:1.2rem;font-size:1.4rem;font-family:var(--font-display);font-weight:600;}
    .stats-bar{display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:2rem;justify-content:center;}
    .stat-chip{background:var(--card);border-radius:50px;padding:.45rem 1.1rem;
               font-size:.82rem;color:var(--muted);box-shadow:var(--shadow);
               border:1px solid var(--border);}
    .stat-chip strong{color:var(--primary);font-family:var(--font-mono);}

    /* Waypoint path — course order matters (Genesis → Revelation), so the
       list is a single winding trail with numbered stations rather than a grid. */
    .course-grid{position:relative;display:flex;flex-direction:column;gap:1.1rem;
                max-width:640px;margin:0 auto;padding-left:2.6rem;
                counter-reset:waypoint;}
    .course-grid::before{content:'';position:absolute;left:.95rem;top:.6rem;bottom:.6rem;
                         width:2px;background:linear-gradient(var(--accent),var(--primary-lt));
                         opacity:.4;}
    .course-card{counter-increment:waypoint;background:var(--card);border-radius:var(--radius);
                padding:1.1rem 1.3rem;box-shadow:var(--shadow);cursor:pointer;
                border:1px solid var(--border);transition:all .2s ease;position:relative;}
    .course-card::before{content:counter(waypoint);position:absolute;left:-2.6rem;top:50%;
                         transform:translateY(-50%);width:1.9rem;height:1.9rem;border-radius:50%;
                         background:var(--card);border:2px solid var(--accent);color:var(--primary);
                         font-family:var(--font-mono);font-weight:600;font-size:.8rem;
                         display:flex;align-items:center;justify-content:center;z-index:1;}
    .course-card:hover{border-color:var(--primary-lt);transform:translateX(3px);}
    .course-card:hover::before{background:var(--accent);color:#fff;border-color:var(--accent);}
    .course-card h3{color:var(--primary);font-size:1.02rem;margin-bottom:.3rem;
                    font-family:var(--font-display);font-weight:600;}
    .course-card p{font-size:.85rem;color:var(--muted);}
    .course-card .q-count{margin-top:.6rem;font-size:.76rem;
                          color:var(--accent);font-weight:600;font-family:var(--font-mono);}
    .course-card .best-badge{position:absolute;top:.7rem;right:.7rem;background:#e9f5ee;
                              color:var(--success);font-size:.7rem;padding:.2rem .55rem;
                              border-radius:50px;font-weight:600;display:none;}
    .testament-label{font-size:.72rem;text-transform:uppercase;letter-spacing:1.2px;
                     color:var(--accent);margin-top:1.8rem;margin-bottom:.8rem;font-weight:700;
                     font-family:var(--font-mono);padding-left:2.6rem;}
    @media(max-width:580px){
      .course-grid{padding-left:2.2rem;}
      .course-card::before{left:-2.2rem;width:1.6rem;height:1.6rem;font-size:.72rem;}
      .course-grid::before{left:.75rem;}
    }

    /* ── Quiz Screen ── */
    #quizScreen{display:none;}
    .quiz-header{background:var(--card);border-radius:var(--radius);padding:1.3rem 1.5rem;
                 box-shadow:var(--shadow);margin-bottom:1.3rem;}
    .quiz-header h2{color:var(--primary);font-size:1.25rem;font-family:var(--font-display);font-weight:600;}
    .quiz-meta{font-size:.82rem;color:var(--muted);margin-top:.3rem;font-family:var(--font-mono);}
    .progress-wrap{margin-top:.9rem;}
    .progress-info{display:flex;justify-content:space-between;font-size:.8rem;
                   color:var(--muted);margin-bottom:.35rem;}
    .progress-bar{height:8px;background:#e0e0e0;border-radius:50px;overflow:hidden;}
    .progress-fill{height:100%;background:linear-gradient(90deg,var(--primary),var(--accent));
                   border-radius:50px;transition:width .4s ease;}

    .question-card{background:var(--card);border-radius:var(--radius);
                   padding:1.8rem 1.8rem 1.4rem;box-shadow:var(--shadow);margin-bottom:1.2rem;}
    .q-number{font-size:.75rem;text-transform:uppercase;letter-spacing:.8px;
              color:var(--accent);font-weight:700;margin-bottom:.6rem;font-family:var(--font-mono);}
    .q-text{font-size:1.15rem;font-weight:600;margin-bottom:1.3rem;line-height:1.5;
            font-family:var(--font-display);}
    .q-verse{font-size:.82rem;color:var(--muted);font-style:italic;
             margin-bottom:1.1rem;padding:.5rem .8rem;background:#f8f9fa;
             border-left:3px solid var(--accent);border-radius:4px;}
    .options{display:flex;flex-direction:column;gap:.7rem;}
    .opt{padding:.9rem 1.1rem;border:2px solid var(--border);border-radius:var(--radius);
         cursor:pointer;transition:all .18s ease;font-size:.96rem;
         display:flex;align-items:center;gap:.8rem;background:#fff;}
    .opt:hover:not(.locked){border-color:var(--primary);background:#F5F1FC;}
    .opt .opt-letter{width:28px;height:28px;border-radius:50%;background:#F0EAFB;
                     color:var(--primary);font-weight:700;font-size:.82rem;
                     display:flex;align-items:center;justify-content:center;flex-shrink:0;
                     font-family:var(--font-mono);}
    .opt.selected{border-color:var(--primary);background:#F0EAFB;}
    .opt.correct{border-color:var(--success)!important;background:#e8f5e9!important;}
    .opt.correct .opt-letter{background:var(--success);color:#fff;}
    .opt.wrong{border-color:var(--danger)!important;background:#ffebee!important;}
    .opt.wrong .opt-letter{background:var(--danger);color:#fff;}
    .opt.locked{cursor:default;}
    .opt .tick{margin-left:auto;font-size:1.1rem;display:none;}
    .opt.correct .tick::after{content:"✓";color:var(--success);display:block;}
    .opt.wrong .tick::after{content:"✗";color:var(--danger);display:block;}
    .opt.correct .tick,.opt.wrong .tick{display:block;}

    .explanation{margin-top:1rem;padding:.8rem 1rem;background:#fffde7;
                 border-left:3px solid var(--accent);border-radius:4px;
                 font-size:.85rem;color:#555;display:none;}
    .explanation.show{display:block;}

    .quiz-nav{display:flex;gap:.8rem;flex-wrap:wrap;}
    .btn{padding:.75rem 1.5rem;border:none;border-radius:var(--radius);
         font-size:.95rem;font-weight:600;cursor:pointer;transition:all .2s ease;}
    .btn-primary{background:var(--primary);color:#fff;}
    .btn-primary:hover{background:var(--primary-dk);}
    .btn-outline{background:transparent;border:2px solid var(--primary);color:var(--primary);}
    .btn-outline:hover{background:var(--primary);color:#fff;}
    .btn-back{background:#F0EAFB;color:var(--primary);}
    .btn-back:hover{background:#E3D8F7;}
    .btn:disabled{opacity:.45;cursor:not-allowed;}

    /* ── Results Screen ── */
    #resultsScreen{display:none;}
    .results-card{background:var(--card);border-radius:var(--radius);
                  padding:2.2rem;box-shadow:var(--shadow);text-align:center;
                  margin-bottom:1.2rem;}
    .score-ring{width:140px;height:140px;border-radius:50%;margin:1rem auto;
                display:flex;align-items:center;justify-content:center;flex-direction:column;
                font-size:2.4rem;font-weight:700;border:8px solid var(--primary);
                font-family:var(--font-mono);}
    .score-ring.excellent{border-color:var(--success);color:var(--success);}
    .score-ring.good{border-color:var(--primary);color:var(--primary);}
    .score-ring.fair{border-color:var(--accent);color:#9a7a00;}
    .score-ring.poor{border-color:var(--danger);color:var(--danger);}
    .score-pct{font-size:.9rem;font-weight:600;margin-top:-.2rem;font-family:var(--font-body);}
    .grade-msg{font-size:1.25rem;font-weight:600;margin:.8rem 0;font-family:var(--font-display);color:var(--primary);}
    .grade-verse{font-style:italic;color:var(--muted);font-size:.88rem;
                 max-width:500px;margin:.5rem auto 1.5rem;line-height:1.6;}
    .result-stats{display:flex;justify-content:center;gap:2rem;
                  flex-wrap:wrap;margin:1rem 0;}
    .r-stat{text-align:center;}
    .r-stat .val{font-size:1.5rem;font-weight:700;color:var(--primary);}
    .r-stat .lbl{font-size:.75rem;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;}
    .review-list{text-align:left;margin-top:1.2rem;}
    .review-item{padding:.9rem 1rem;border-bottom:1px solid var(--border);font-size:.88rem;}
    .review-item:last-child{border-bottom:none;}
    .review-item .rv-q{font-weight:600;margin-bottom:.3rem;}
    .review-item .rv-a{color:var(--success);} .review-item .rv-w{color:var(--danger);}

    /* ── Toast ── */
    #toast{position:fixed;bottom:1.5rem;right:1.5rem;background:#333;color:#fff;
           padding:.7rem 1.2rem;border-radius:var(--radius);font-size:.88rem;
           opacity:0;pointer-events:none;transition:opacity .3s ease;z-index:999;}
    #toast.show{opacity:1;}

    @media(max-width:580px){
      .hero{padding:3.4rem 1.2rem 3rem;}
      .hero-stats{gap:1.6rem;}
      .question-card{padding:1.2rem;}
      .q-text{font-size:1rem;}
    }
  </style>
</head>
<body>

<nav class="site-nav">
  <a class="wordmark" href="#top">Foundation<span>s</span></a>
  <ul class="nav-links">
    <li><a href="#top">About</a></li>
    <li><a href="#purpose">Our Purpose</a></li>
    <li><a href="#quiz">Take the Quiz</a></li>
  </ul>
</nav>

<section class="hero" id="top">
  <div class="eyebrow">A Devotional Survey of Scripture</div>
  <h1>From Genesis to Revelation, <em>book by book.</em></h1>
  <p class="lede">Foundations walks new believers and lifelong disciples alike through
     the whole of Scripture. Test what you've learned with a quiz built for every
     course in the series.</p>
  <a class="hero-cta" href="#quiz">Test Your Foundations ↓</a>
  <div class="hero-stats">
    <div class="hstat"><div class="hnum" id="heroCourses">15</div><div class="hlbl">Courses</div></div>
    <div class="hstat"><div class="hnum" id="heroQuestions">0</div><div class="hlbl">Quiz Questions</div></div>
    <div class="hstat"><div class="hnum">66</div><div class="hlbl">Books Covered</div></div>
  </div>
</section>

<section class="purpose" id="purpose">
  <div class="section-label">Why Foundations</div>
  <h2>Scripture, made for discipleship</h2>
  <div class="purpose-grid">
    <div class="purpose-card">
      <div class="p-icon">🌱</div>
      <h3>Make Disciples</h3>
      <p>Practical, devotional lessons for those who are new to faith in Christ.</p>
    </div>
    <div class="purpose-card">
      <div class="p-icon">🕊️</div>
      <h3>Strengthen Believers</h3>
      <p>A survey of the whole Bible to deepen and nurture a growing faith.</p>
    </div>
    <div class="purpose-card">
      <div class="p-icon">⛪</div>
      <h3>Grow the Church</h3>
      <p>Courses designed to be studied, discussed, and shared in community.</p>
    </div>
  </div>
</section>

<div class="app" id="quiz">
  <div class="app-intro">
    <div class="section-label">Quiz Bank</div>
    <h2>Test Your Foundations</h2>
    <p>Choose any course below and see how well you know it. Your best score
       on each is saved right here in your browser.</p>
  </div>

  <!-- ── COURSE SELECT ── -->
  <div id="courseScreen">
    <div class="stats-bar">
      <div class="stat-chip">📚 <strong>15</strong> Courses</div>
      <div class="stat-chip">❓ <strong id="totalQCount">0</strong> Questions</div>
      <div class="stat-chip">🏆 Best scores saved locally</div>
    </div>
    <p class="testament-label">Old Testament</p>
    <div class="course-grid" id="otGrid"></div>
    <p class="testament-label" style="margin-top:1.6rem;">New Testament &amp; Thematic</p>
    <div class="course-grid" id="ntGrid"></div>
  </div>

  <!-- ── QUIZ ── -->
  <div id="quizScreen">
    <div class="quiz-header">
      <h2 id="qzTitle"></h2>
      <div class="quiz-meta" id="qzMeta"></div>
      <div class="progress-wrap">
        <div class="progress-info">
          <span id="qzProg"></span>
          <span id="qzScore">Score: 0</span>
        </div>
        <div class="progress-bar"><div class="progress-fill" id="progFill"></div></div>
      </div>
    </div>

    <div class="question-card">
      <div class="q-number" id="qNum"></div>
      <div class="q-text"  id="qText"></div>
      <div class="q-verse" id="qVerse" style="display:none;"></div>
      <div class="options"  id="qOpts"></div>
      <div class="explanation" id="qExpl"></div>
    </div>

    <div class="quiz-nav">
      <button class="btn btn-back"    id="btnBack">← Courses</button>
      <button class="btn btn-outline" id="btnPrev" disabled>‹ Prev</button>
      <button class="btn btn-primary" id="btnNext">Next ›</button>
      <button class="btn btn-primary" id="btnSubmit" style="display:none;">Submit Quiz</button>
    </div>
  </div>

  <!-- ── RESULTS ── -->
  <div id="resultsScreen">
    <div class="results-card">
      <h2 id="rTitle" style="color:var(--primary);margin-bottom:.5rem;"></h2>
      <div class="score-ring" id="scoreRing">
        <span id="scoreNum"></span>
        <span class="score-pct" id="scorePct"></span>
      </div>
      <div class="grade-msg"   id="gradeMsg"></div>
      <div class="grade-verse" id="gradeVerse"></div>
      <div class="result-stats">
        <div class="r-stat"><div class="val" id="rCorrect"></div><div class="lbl">Correct</div></div>
        <div class="r-stat"><div class="val" id="rWrong"></div><div class="lbl">Wrong</div></div>
        <div class="r-stat"><div class="val" id="rTime"></div><div class="lbl">Time</div></div>
        <div class="r-stat"><div class="val" id="rBest"></div><div class="lbl">Best</div></div>
      </div>
      <div style="display:flex;gap:.8rem;justify-content:center;flex-wrap:wrap;margin-top:1.2rem;">
        <button class="btn btn-primary" id="btnRetake">Retake Quiz</button>
        <button class="btn btn-outline" id="btnReview">Review Answers</button>
        <button class="btn btn-back"    id="btnToCourses">All Courses</button>
      </div>
    </div>
    <div class="results-card" id="reviewSection" style="display:none;">
      <h3 style="color:var(--primary);margin-bottom:1rem;">Answer Review</h3>
      <div class="review-list" id="reviewList"></div>
    </div>
  </div>
</div>

<footer>
  <div class="foot-word">Foundation<span style="color:var(--accent-lt);">s</span></div>
  <div class="foot-links">
    <a href="#top">About</a>
    <a href="#purpose">Our Purpose</a>
    <a href="#quiz">Quiz Bank</a>
  </div>
  <div>© 2026 Foundations. A devotional survey of the Bible, from Genesis to Revelation.</div>
</footer>

<div id="toast"></div>

<script>
// ══════════════════════════════════════════════════════════
//  QUIZ DATA  –  Foundations course series, Genesis to Revelation
// ══════════════════════════════════════════════════════════
const COURSES = [
  // ── 1. Introduction to the Bible ──────────────────────
  {
    id:"intro_bible", title:"Introduction to the Bible",
    testament:"ot",
    desc:"Purpose, structure, and overview of Scripture",
    questions:[
      { q:"What are the two main sections of the Bible?",
        opts:["History and Prophecy","Old Testament and New Testament","Law and Gospel","Poetry and Letters"],
        a:1, verse:"2 Timothy 3:16",
        expl:"The Bible is divided into the Old Testament (39 books) and the New Testament (27 books)." },
      { q:"How many books are in the entire Bible?",
        opts:["60","66","72","80"],
        a:1, verse:"",
        expl:"The Bible contains 66 books: 39 in the OT and 27 in the NT." },
      { q:"According to 2 Timothy 3:16, all Scripture is given by inspiration of God and is profitable for:",
        opts:["Entertainment and culture","Doctrine, reproof, correction, and instruction in righteousness","History and geography","Science and philosophy"],
