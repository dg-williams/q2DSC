// Pre-compute total questions
const totalQ = COURSES.reduce((sum,c) => sum + c.questions.length, 0);

// ── State ───────────────────────────────────────────────
let state = {
  course: null,
  qi: 0,
  answers: [],
  revealed: [],
  score: 0,
  startTime: null,
  timerInt: null,
};

// ── DOM ─────────────────────────────────────────────────
const courseScreen  = document.getElementById("courseScreen");
const quizScreen    = document.getElementById("quizScreen");
const resultsScreen = document.getElementById("resultsScreen");

// ── Init ────────────────────────────────────────────────
document.addEventListener("DOMContentLoaded", () => {
  document.getElementById("totalQCount").textContent = totalQ;
  document.getElementById("heroQuestions").textContent = totalQ;
  document.getElementById("heroCourses").textContent = COURSES.length;
  renderCourseSelect();

  document.getElementById("btnBack").addEventListener("click", goToCourses);
  document.getElementById("btnPrev").addEventListener("click", () => navigate(-1));
  document.getElementById("btnNext").addEventListener("click", () => navigate(1));
  document.getElementById("btnSubmit").addEventListener("click", submitQuiz);
  document.getElementById("btnRetake").addEventListener("click", () => startQuiz(state.course.id));
  document.getElementById("btnReview").addEventListener("click", toggleReview);
  document.getElementById("btnToCourses").addEventListener("click", goToCourses);
});

// ── Render course cards ──────────────────────────────────
function renderCourseSelect(){
  ["ot","nt"].forEach(t => {
    const grid = document.getElementById(t === "ot" ? "otGrid" : "ntGrid");
    grid.innerHTML = "";
    COURSES.filter(c => c.testament === t).forEach(c => {
      const best = getBest(c.id);
      const div = document.createElement("div");
      div.className = "course-card";
      div.innerHTML = `
        <div class="best-badge" id="best-${c.id}">${best !== null ? best+"%" : ""}</div>
        <h3>${c.title}</h3>
        <p>${c.desc}</p>
        <div class="q-count">📝 ${c.questions.length} questions</div>`;
      if(best !== null){
        div.querySelector(".best-badge").style.display = "block";
      }
      div.addEventListener("click", () => startQuiz(c.id));
      grid.appendChild(div);
    });
  });
}

// ── Start quiz ───────────────────────────────────────────
function startQuiz(courseId){
  const course = COURSES.find(c => c.id === courseId);
  if(!course) return;
  state = {
    course,
    qi: 0,
    answers: Array(course.questions.length).fill(null),
    revealed: Array(course.questions.length).fill(false),
    score: 0,
    startTime: Date.now(),
    timerInt: null,
  };
  document.getElementById("qzTitle").textContent = course.title;
  document.getElementById("qzMeta").textContent =
    `${course.questions.length} questions  •  Foundations`;

  showScreen("quiz");
  renderQuestion();
}

// ── Render question ──────────────────────────────────────
function renderQuestion(){
  const { course, qi, answers, revealed } = state;
  const q = course.questions[qi];
  const total = course.questions.length;

  document.getElementById("qNum").textContent  = `Question ${qi+1} of ${total}`;
  document.getElementById("qText").textContent = q.q;

  const verseEl = document.getElementById("qVerse");
  if(q.verse){ verseEl.textContent = "📖 " + q.verse; verseEl.style.display="block"; }
  else { verseEl.style.display = "none"; }

  const explEl = document.getElementById("qExpl");
  explEl.textContent = q.expl;
  explEl.classList.toggle("show", revealed[qi]);

  // Options
  const optsEl = document.getElementById("qOpts");
  optsEl.innerHTML = "";
  const letters = ["A","B","C","D","E"];
  q.opts.forEach((opt, i) => {
    const div = document.createElement("div");
    div.className = "opt";
    div.innerHTML = `<span class="opt-letter">${letters[i]}</span>
                     <span>${opt}</span><span class="tick"></span>`;
    if(revealed[qi]){
      div.classList.add("locked");
      if(i === q.a) div.classList.add("correct");
      else if(i === answers[qi] && answers[qi] !== q.a) div.classList.add("wrong");
    } else {
      if(answers[qi] === i) div.classList.add("selected");
      div.addEventListener("click", () => selectAnswer(i));
    }
    optsEl.appendChild(div);
  });

  // Progress
  const pct = ((qi+1)/total*100).toFixed(0);
  document.getElementById("qzProg").textContent  = `Question ${qi+1} / ${total}`;
  document.getElementById("qzScore").textContent = `Score: ${state.score}`;
  document.getElementById("progFill").style.width = pct + "%";

  // Nav buttons
  document.getElementById("btnPrev").disabled = (qi === 0);
  const isLast = qi === total-1;
  document.getElementById("btnNext").style.display    = isLast ? "none" : "inline-block";
  document.getElementById("btnSubmit").style.display  = isLast ? "inline-block" : "none";
}

// ── Select answer ────────────────────────────────────────
function selectAnswer(idx){
  const { course, qi } = state;
  if(state.revealed[qi]) return;
  const q = course.questions[qi];

  state.answers[qi]  = idx;
  state.revealed[qi] = true;
  if(idx === q.a) {
    state.score++;
    showToast("✓ Correct!");
  } else {
    showToast("✗ Incorrect — see explanation below");
  }
  renderQuestion();
}

// ── Navigate ─────────────────────────────────────────────
function navigate(dir){
  const newIdx = state.qi + dir;
  if(newIdx >= 0 && newIdx < state.course.questions.length){
    state.qi = newIdx;
    renderQuestion();
  }
}

// ── Submit ───────────────────────────────────────────────
function submitQuiz(){
  // Auto-reveal any unanswered questions
  state.course.questions.forEach((q, i) => {
    if(state.answers[i] === null){
      state.answers[i] = -1;
      state.revealed[i] = true;
    }
  });

  const total = state.course.questions.length;
  const pct   = Math.round(state.score / total * 100);
  const elapsed = Math.round((Date.now() - state.startTime) / 1000);
  const mm = String(Math.floor(elapsed/60)).padStart(2,"0");
  const ss = String(elapsed % 60).padStart(2,"0");

  // Save best
  saveBest(state.course.id, pct);

  // Score ring class
  const ring = document.getElementById("scoreRing");
  ring.className = "score-ring " +
    (pct>=90?"excellent": pct>=70?"good": pct>=50?"fair":"poor");
  document.getElementById("scoreNum").textContent = `${state.score}/${total}`;
  document.getElementById("scorePct").textContent = pct + "%";

  // Grade message & verse
  const grades = [
    { min:90, msg:"Outstanding! 🌟", verse:"Well done, good and faithful servant! — Matthew 25:21" },
    { min:70, msg:"Great work! 👍",   verse:"Study to show yourself approved unto God. — 2 Timothy 2:15" },
    { min:50, msg:"Good effort! 📖",  verse:"Your word is a lamp to my feet and a light to my path. — Psalm 119:105" },
    { min:0,  msg:"Keep studying! 💪",verse:"Blessed is the one who finds wisdom. — Proverbs 3:13" },
  ];
  const g = grades.find(x => pct >= x.min);
  document.getElementById("gradeMsg").textContent   = g.msg;
  document.getElementById("gradeVerse").textContent = g.verse;
  document.getElementById("rTitle").textContent     = state.course.title + " — Results";
  document.getElementById("rCorrect").textContent   = state.score;
  document.getElementById("rWrong").textContent     = total - state.score;
  document.getElementById("rTime").textContent      = `${mm}:${ss}`;
  document.getElementById("rBest").textContent      = getBest(state.course.id) + "%";

  // Build review
  const reviewList = document.getElementById("reviewList");
  reviewList.innerHTML = state.course.questions.map((q, i) => {
    const ua = state.answers[i];
    const correct = ua === q.a;
    return `<div class="review-item">
      <div class="rv-q">${i+1}. ${q.q}</div>
      <div class="${correct?"rv-a":"rv-w"}">
        ${correct ? "✓ Correct: " : "✗ Your answer: "}
        ${ua >= 0 ? q.opts[ua] : "Not answered"}
      </div>
      ${!correct ? `<div class="rv-a">✓ Correct: ${q.opts[q.a]}</div>` : ""}
      <div style="color:#777;font-size:.8rem;margin-top:.3rem;">${q.expl}</div>
    </div>`;
  }).join("");

  document.getElementById("reviewSection").style.display = "none";
  showScreen("results");
}

// ── Toggle review ─────────────────────────────────────────
function toggleReview(){
  const sec = document.getElementById("reviewSection");
  sec.style.display = sec.style.display === "none" ? "block" : "none";
}

// ── Navigation helpers ────────────────────────────────────
function goToCourses(){
  showScreen("course");
  renderCourseSelect();
}
function showScreen(s){
  courseScreen.style.display  = s==="course"  ? "block" : "none";
  quizScreen.style.display    = s==="quiz"    ? "block" : "none";
  resultsScreen.style.display = s==="results" ? "block" : "none";
  window.scrollTo(0,0);
}

// ── Local storage best scores ─────────────────────────────
function getBest(id){
  return JSON.parse(localStorage.getItem("bf_best_"+id) ?? "null");
}
function saveBest(id, pct){
  const cur = getBest(id);
  if(cur === null || pct > cur) localStorage.setItem("bf_best_"+id, JSON.stringify(pct));
}

// ── Toast ─────────────────────────────────────────────────
let toastTimer;
function showToast(msg){
  const t = document.getElementById("toast");
  t.textContent = msg;
  t.classList.add("show");
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove("show"), 2000);
}
</script>
